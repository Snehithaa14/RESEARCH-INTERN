1. performance_metrics.py

def calculate_detection_rate(detected, total_attacks):
    return (detected / total_attacks) * 100

def calculate_compromised_ratio(compromised, total_nodes):
    return compromised / total_nodes

detected = 17
total_attacks = 20

compromised = 4
total_nodes = 25

print("Detection Rate:", calculate_detection_rate(detected, total_attacks), "%")
print("Compromised Ratio:", calculate_compromised_ratio(compromised, total_nodes))




